[2078.850235, "o", "SED(1)                                       User Commands                                      SED(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       sed - stream editor for filtering and transforming text\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       sed [-V] [--version] [--help] [-n] [--quiet] [--silent]\u001b[m\r\n           [-l N] [--line-length=N] [-u] [--unbuffered]\u001b[m\r\n           [-E] [-r] [--regexp-extended]\u001b[m\r\n           [-e script] [--expression=script]\u001b[m\r\n           [-f script-file] [--file=script-file]\u001b[m\r\n           [script-if-no-other-script]\u001b[m\r\n\u001b[7m Manual page sed(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
