[2082.303378, "o", "\u001b[1;1HSED(1)                                       User Commands                                      SED(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       sed - stream editor for filtering and transforming text\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       sed [-V] [--version] [--help] [-n] [--quiet] [--silent]\u001b[m\r\n\u001b[8;1H           [-l N] [--line-length=N] [-u] [--unbuffered]\u001b[m\r\n\u001b[9;1H           [-E] [-r] [--regexp-extended]\u001b[m\r\n\u001b[10;1H           [-e script] [--expression=script]\u001b[m\r\n\u001b[11;1H           [-f script-file] [--file=script-file]\u001b[m\r\n\u001b[12;1H           [script-if-no-other-script]\u001b[m\r\n\u001b[13;1H\u001b[1;1HSED(1)                                       User Commands                                      SED(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       sed - stream editor for filtering and transforming text\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       sed [-V] [--version] [--help] [-n] [--quiet] [--silent]\u001b[m\r\n\u001b[8;1H           [-l N] [--line-length=N] [-u] [--unbuffered]\u001b[m\r\n\u001b[9;1H"]
[2082.303391, "o", "           [-E] [-r"]
[2082.303666, "o", "] [--regexp-extended]\u001b[m\r\n\u001b[10;1H           [-e script] [--expression=script]\u001b[m\r\n\u001b[11;1H           [-f script-file] [--file=script-file]\u001b[m\r\n\u001b[12;1H           [script\u001b[7m-i\u001b[27mf-no-other-script]\u001b[m\r\n\u001b[13;1H           [file...]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[4mSed\u001b[24m  is  a  stream editor.  A stream editor is used to perform basic text transformations on an\u001b[m\r\n       input stream (a file or input from a pipeline).  While in some ways similar to an editor  which\u001b[m\r\n       permits  scripted  edits (such as \u001b[4med\u001b[24m), \u001b[4msed\u001b[24m works by making only one pass over the input(s), and\u001b[m\r\n       is consequently more efficient.  But it is \u001b[4msed\u001b[24m's ability to filter text  in  a  pipeline  which\u001b[m\r\n       particularly distinguishes it from other types of editors.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-n\u001b[0m, \u001b[1m--quiet\u001b[0m, \u001b[1m--silent\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page sed(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K"]
[2083.090632, "o", "\r\u001b[K/\r\u001b[K"]
[2083.090757, "o", "...skipping...\r\n       \u001b[1m\u001b[7m-i\u001b[27m\u001b[0m\u001b[1m[SUFFIX]\u001b[0m, \u001b[1m-\u001b[0m\u001b[1m\u001b[7m-i\u001b[27m\u001b[0m\u001b[1mn-place\u001b[0m[=\u001b[4mSUFFIX\u001b[24m]\u001b[m\r\n\u001b[m\r\n              edit files in place (makes backup if SUFFIX supplied)\u001b[m\r\n\u001b[m\r\n       \u001b[1m-l\u001b[0m N, \u001b[1m--line-length\u001b[0m=\u001b[4mN\u001b[24m\u001b[m\r\n\u001b[m\r\n              specify the desired line-wrap length for the `l' command\u001b[m\r\n\u001b[m\r\n       \u001b[1m--posix\u001b[0m\u001b[m\r\n\u001b[m\r\n              disable all GNU extensions.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page sed(1) line 42 (press h for help or q to quit)\u001b[27m\u001b[K"]
