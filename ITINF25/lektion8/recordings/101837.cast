[8362.773529, "o", "TR(1)                                        User Commands                                       TR(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       tr - translate or delete characters\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mtr\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mSTRING1\u001b[24m [\u001b[4mSTRING2\u001b[24m]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Translate,  squeeze,  and/or delete characters from standard input, writing to standard output.\u001b[m\r\n       STRING1 and STRING2 specify arrays of characters ARRAY1 and ARRAY2 that control the action.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[0m, \u001b[1m-C\u001b[0m, \u001b[1m--complement\u001b[0m\u001b[m\r\n              use the complement of ARRAY1\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--delete\u001b[0m\u001b[m\r\n              delete characters in ARRAY1, do not translate\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[0m, \u001b[1m--squeeze-repeats\u001b[0m\u001b[m\r\n              replace each sequence of a repeated character that is listed in the last  specified  AR‐\u001b[m\r\n              RAY, with a single occurrence of that character\u001b[m\r\n\u001b[7m Manual page tr(1) line 1 (press h for help or q to qu"]
[8362.773627, "o", "it)\u001b[27m\u001b[K"]
[8372.802935, "o", "\u001b[H\u001b[2J\u001b[H\u001b[H\u001b[2J\u001b[HTR(1)                                        User Commands                                       TR(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       tr - translate or delete characters\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mtr\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mSTRING1\u001b[24m [\u001b[4mSTRING2\u001b[24m]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Translate,  squeeze,  and/or delete characters from standard input, writing to standard output.\u001b[m\r\n       STRING1 and STRING2 specify arrays of characters ARRAY1 and ARRAY2 that control the action.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[0m, \u001b[1m-C\u001b[0m, \u001b[1m--complement\u001b[0m\u001b[m\r\n              use the complement of ARRAY1\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--delete\u001b[0m\u001b[m\r\n              delete characters in ARRAY1, do not translate\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[0m, \u001b[1m--squeeze-repeats\u001b[0m\u001b[m\r\n              replace each sequence of a repeated character that is listed in the last  specified  AR‐\u001b[m\r\n\u001b[7m Manual page tr(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[8372.846309, "o", "\u001b[H\u001b[2J\u001b[H\u001b[H\u001b[2J\u001b[HTR(1)                                        User Commands                                       TR(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       tr - translate or delete characters\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mtr\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mSTRING1\u001b[24m [\u001b[4mSTRING2\u001b[24m]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Translate,  squeeze,  and/or delete characters from standard input, writing to standard output.\u001b[m\r\n       STRING1 and STRING2 specify arrays of characters ARRAY1 and ARRAY2 that control the action.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[0m, \u001b[1m-C\u001b[0m, \u001b[1m--complement\u001b[0m\u001b[m\r\n              use the complement of ARRAY1\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--delete\u001b[0m\u001b[m\r\n              delete characters in ARRAY1, do not translate\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[0m, \u001b[1m--squeeze-repeats\u001b[0m\u001b[m\r\n\u001b[7m Manual page tr(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[8372.861837, "o", "\u001b[H\u001b[2J\u001b[H\u001b[H\u001b[2J\u001b[HTR(1)                                        User Commands                                       TR(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       tr - translate or delete characters\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mtr\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mSTRING1\u001b[24m [\u001b[4mSTRING2\u001b[24m]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Translate,  squeeze,  and/or delete characters from standard input, writing to standard output.\u001b[m\r\n       STRING1 and STRING2 specify arrays of characters ARRAY1 and ARRAY2 that control the action.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[0m, \u001b[1m-C\u001b[0m, \u001b[1m--complement\u001b[0m\u001b[m\r\n              use the complement of ARRAY1\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--delete\u001b[0m\u001b[m\r\n              delete characters in ARRAY1, do not translate\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page tr(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
