[8605.918585, "o", "\r\u001b[K"]
[8605.918659, "o", "\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Translate,  squeeze,  and/or delete characters from standard input, writing to standard output.\u001b[m\r\n       STRING1 and STRING2 specify arrays of characters ARRAY1 and ARRAY2 that control the action.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[0m, \u001b[1m-C\u001b[0m, \u001b[1m--complement\u001b[0m\u001b[m\r\n              use the complement of ARRAY1\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--delete\u001b[0m\u001b[m\r\n\u001b[7m Manual page tr(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
[8607.706161, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[8607.706181, "o", "              delete characters in ARRAY1, do not translate\u001b[m\r\n\u001b[7m Manual page tr(1) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[8607.847706, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page tr(1) line 11 (press h for help or q to quit)\u001b[27m\u001b[K"]
