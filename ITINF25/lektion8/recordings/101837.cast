[8315.492328, "o", "\u001b[1;1HTR(1)                                        User Commands                                       TR(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       tr - translate or delete characters\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mtr\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mSTRING1\u001b[24m [\u001b[4mSTRING2\u001b[24m]\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H       Translate,  squeeze,  and/or delete characters from standard input, writing to standard output.\u001b[m\r\n\u001b[11;1H       STRING1 and STRING2 specify arrays of characters ARRAY1 and ARRAY2 that control the action.\u001b[m\r\n\u001b[12;1H\u001b[m\r\n\u001b[13;1H       \u001b[1m-c\u001b[0m, \u001b[1m-C\u001b[0m, \u001b[1m--complement\u001b[0m\u001b[m\r\n\u001b[14;1H              use the complement of ARRAY1\u001b[m\r\n\u001b[15;1H\u001b[m\r\n\u001b[16;1H       \u001b[1m-d\u001b[0m, \u001b[1m--delete\u001b[0m\u001b[m\r\n\u001b[17;1H              delete characters in ARRAY1, do not translate\u001b[m\r\n\u001b[18;1H\u001b[m\r\n\u001b[19;1H       \u001b[1m-s\u001b[0m, \u001b[1m--squeeze-repeats\u001b[0m\u001b[m\r\n\u001b[20;1H\u001b[1;1HTR(1)                                        User Commands                                      "]
