      "link": null,
      "locked": false,
      "text": "Exempelvis i Python:\n\nimport urllib.request\nimport urllib.parse\nparams = urllib.parse.urlencode({'spam': 1, 'eggs': 2, 'bacon': 0})\nurl = \"http://www.musi-cal.com/cgi-bin/query?%s\" % params\nwith urllib.request.urlopen(url) as f:\n    print(f.read().decode('utf-8'))",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Exempelvis i Python:\n\nimport urllib.request\nimport urllib.parse\nparams = urllib.parse.urlencode({'spam': 1, 'eggs': 2, 'bacon': 0})\nurl = \"http://www.musi-cal.com/cgi-bin/query?%s\" % params\nwith urllib.request.urlopen(url) as f:\n    print(f.read().decode('utf-8'))",
      "autoResize": true,
      "lineHeight": 1.25
    },
