[67.045864, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 818 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.07746, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       If \u001b[4m--delegation\u001b[24m is provided several times, the last set value will be used.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 817 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.109136, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 816 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.140679, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              always Unconditionally allow the server to delegate.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 815 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.172652, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 814 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.203374, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[67.203498, "o", "\u001b[H\u001bM                     ticket, which is a matter of realm policy.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 813 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.23464, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[67.234771, "o", "\u001b[H\u001bM              policy Delegates  if  and  only if the OK-AS\u001b[7m-D\u001b[27mELEGATE flag is set in the Kerberos service\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 812 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.266297, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 811 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.297638, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              none   Do not allow any delegation.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 810 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.328905, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 809 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.360367, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[67.3605, "o", "\u001b[H\u001bM              to user credentials.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 808 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.392224, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              (GSS/kerberos) Set LEVEL to tell the server what it is allowed to delegate when it  comes\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 807 (press h for help or q to quit)\u001b[27m\u001b[K"]
