[67.45464, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 805 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.486113, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              sive to \u001b[4m-F,\u001b[24m \u001b[4m--form\u001b[24m and \u001b[4m-I,\u001b[24m \u001b[4m--head\u001b[24m and \u001b[4m-T,\u001b[24m \u001b[4m--upload-file\u001b[24m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 804 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.516784, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              See  also  \u001b[4m--data-binary\u001b[24m, \u001b[4m--data-urlencode\u001b[24m and \u001b[4m--data-raw\u001b[24m. This option is mutually exclu‐\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 803 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.547771, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 802 (press h for help or q to quit)\u001b[27m\u001b[K"]
