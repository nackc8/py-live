[66.63735, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 831 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.669063, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              gest.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 830 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.699747, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              Providing \u001b[4m--digest\u001b[24m multiple times has no extra effect.  Disable it  again  with  --no-di‐\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 829 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.731328, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 828 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.76178, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              the normal \u001b[4m-u,\u001b[24m \u001b[4m--user\u001b[24m option to set user name and password.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 827 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.793803, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              the  password  from  being sent over the wire in clear text. Use this in combination with\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 826 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.825283, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              (HTTP) Enables HTTP Digest authentication. This is an authentication scheme that prevents\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 825 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.856835, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       --digest\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 824 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.888188, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 823 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.920109, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       See also \u001b[4m-k,\u001b[24m \u001b[4m--insecure\u001b[24m and \u001b[4m--ssl\u001b[24m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 822 (press h for help or q to quit)\u001b[27m\u001b[K"]
