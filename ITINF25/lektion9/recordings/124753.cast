[55.528384, "o", "curl(1)                                       curl Manual                                       curl(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       curl - transfer a URL\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mcurl\u001b[0m \u001b[1m[options\u001b[0m \u001b[1m/\u001b[0m \u001b[1mURLs]\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mcurl\u001b[0m  is  a  tool  for transferring data from or to a server. It supports these protocols: DICT,\u001b[m\r\n       FILE, FTP, FTPS, GOPHER, GOPHERS, HTTP, HTTPS, IMAP, IMAPS,  LDAP,  LDAPS,  MQTT,  POP3,  POP3S,\u001b[m\r\n       RTMP,  RTMPS,  RTSP, SCP, SFTP, SMB, SMBS, SMTP, SMTPS, TELNET, TFTP, WS and WSS. The command is\u001b[m\r\n       designed to work without user interaction.\u001b[m\r\n\u001b[m\r\n       curl offers a busload of useful tricks like proxy support, user authentication, FTP upload, HTTP\u001b[m\r\n       post, SSL connections, cookies, file transfer resume and more. As you will see below, the number\u001b[m\r\n       of features will make your head spin.\u001b[m\r\n\u001b[m\r\n       curl is powered by libcurl for all transfer-related features. See \u001b[4mlib"]
[55.528484, "o", "curl(3)\u001b[24m for details.\u001b[m\r\n\u001b[m\r\n\u001b[1mURL\u001b[0m\u001b[m\r\n       The URL syntax is protocol-dependent. You find a detailed description in RFC 3986.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page curl(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[56.125699, "o", "\r\u001b[K/"]
[56.741084, "o", "\u001b[K-\b-"]
[57.183954, "o", "\u001b[KD\bD"]
[57.469237, "o", "\r\u001b[K"]
[57.469647, "o", "\u001b[1;1Hcurl(1)                                       curl Manual                                       curl(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       curl - transfer a URL\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mcurl\u001b[0m \u001b[1m[options\u001b[0m \u001b[1m/\u001b[0m \u001b[1mURLs]\u001b[0m\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H       \u001b[1mcurl\u001b[0m  is  a  tool  for transferring data from or to a server. It supports these protocols: DICT,\u001b[m\r\n\u001b[11;1H       FILE, FTP, FTPS, GOPHER, GOPHERS, HTTP, HTTPS, IMAP, IMAPS,  LDAP,  LDAPS,  MQTT,  POP3,  POP3S,\u001b[m\r\n\u001b[12;1H       RTMP,  RTMPS,  RTSP, SCP, SFTP, SMB, SMBS, SMTP, SMTPS, TELNET, TFTP, WS and WSS. The command is\u001b[m\r\n\u001b[13;1H       designed to work without user interaction.\u001b[m\r\n\u001b[14;1H\u001b[m\r\n\u001b[15;1H       curl offers a busload of useful tricks like proxy support, user authentication, FTP upload, HTTP\u001b[m\r\n\u001b[16;1H       post, SSL connections, cookies, file transfer resume and more. As you will see below, the number\u001b[m\r\n\u001b[17;1H       of features will "]
[57.469659, "o", "make your head "]
[57.469784, "o", "spin.\u001b[m\r\n\u001b[18;1H\u001b[m\r\n\u001b[19;1H       curl is powered by libcurl for all transfer-related features. See \u001b[4mlibcurl(3)\u001b[24m for details.\u001b[m\r\n\u001b[20;1H\u001b[m\r\n\u001b[21;1H\u001b[1mURL\u001b[0m\u001b[m\r\n\u001b[22;1H       The URL syntax is protocol-dependent. You find a detailed description in RFC 3986.\u001b[m\r\n\u001b[23;1H\u001b[m\r\n\u001b[24;1H\u001b[1;1Hcurl(1)                                       curl Manual                                       curl(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       curl - transfer a URL\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mcurl\u001b[0m \u001b[1m[options\u001b[0m \u001b[1m/\u001b[0m \u001b[1mURLs]\u001b[0m\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H       \u001b[1mcurl\u001b[0m  is  a  tool  for transferring data from or to a server. It supports these protocols: DICT,\u001b[m\r\n\u001b[11;1H       FILE, FTP, FTPS, GOPHER, GOPHERS, HTTP, HTTPS, IMAP, IMAPS,  LDAP,  LDAPS,  MQTT,  POP3,  POP3S,\u001b[m\r\n\u001b[12;1H       RTMP,  RTMPS,  RTSP, SCP, SFTP, SMB, SMBS, SMTP, SMTPS, TELNET, TFTP, WS and WSS. The command is\u001b[m\r\n\u001b[13;1H       designed to work without u"]
[57.469802, "o", "ser interaction.\u001b["]
[57.470095, "o", "m\r\n\u001b[14;1H\u001b[m\r\n\u001b[15;1H       curl offers a busload of useful tricks like proxy support, user authentication, FTP upload, HTTP\u001b[m\r\n\u001b[16;1H       post, SSL connections, cookies, file transfer resume and more. As you will see below, the number\u001b[m\r\n\u001b[17;1H       of features will make your head spin.\u001b[m\r\n\u001b[18;1H\u001b[m\r\n\u001b[19;1H       curl is powered by libcurl for all transfer-related features. See \u001b[4mlibcurl(3)\u001b[24m for details.\u001b[m\r\n\u001b[20;1H\u001b[m\r\n\u001b[21;1H\u001b[1mURL\u001b[0m\u001b[m\r\n\u001b[22;1H       The URL syntax is protocol-dependent. You find a detailed description in RFC 3986.\u001b[m\r\n\u001b[23;1H\u001b[m\r\n\u001b[24;1H"]
[57.471892, "o", "...skipping...\r\n              policy Delegates  if  and  only if the OK-AS\u001b[7m-D\u001b[27mELEGATE flag is set in the Kerberos service\u001b[m\r\n                     ticket, which is a matter of realm policy.\u001b[m\r\n\u001b[m\r\n              always Unconditionally allow the server to delegate.\u001b[m\r\n\u001b[m\r\n       If \u001b[4m--delegation\u001b[24m is provided several times, the last set value will be used.\u001b[m\r\n\u001b[m\r\n       Example:\u001b[m\r\n        curl --delegation \"none\" https://example.com\u001b[m\r\n\u001b[m\r\n       See also \u001b[4m-k,\u001b[24m \u001b[4m--insecure\u001b[24m and \u001b[4m--ssl\u001b[24m.\u001b[m\r\n\u001b[m\r\n       --digest\u001b[m\r\n              (HTTP) Enables HTTP Digest authentication. This is an authentication scheme that prevents\u001b[m\r\n              the  password  from  being sent over the wire in clear text. Use this in combination with\u001b[m\r\n              the normal \u001b[4m-u,\u001b[24m \u001b[4m--user\u001b[24m option to set user name and password.\u001b[m\r\n\u001b[m\r\n              Providing \u001b[4m--digest\u001b[24m multiple times has no extra effect.  Disable it  again  with  --no-di‐\u001b[m\r\n              gest.\u001b[m\r\n\u001b"]
[57.471991, "o", "[m\r\n              Example:\u001b[m\r\n               curl -u name:password --digest https://example.com\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page curl(1) line 812 (press h for help or q to quit)\u001b[27m\u001b[K"]
[58.436349, "o", "\r\u001b[K/\r\u001b[K"]
[58.436723, "o", "...skipping...\r\n       \u001b[7m-D\u001b[27m, --dump-header <filename>\u001b[m\r\n              (HTTP FTP) Write the received protocol headers to the specified file. If no  headers  are\u001b[m\r\n              received, the use of this option will create an empty file.\u001b[m\r\n\u001b[m\r\n              When  used  in FTP, the FTP server response lines are considered being \"headers\" and thus\u001b[m\r\n              are saved there.\u001b[m\r\n\u001b[m\r\n              Having multiple transfers in one set of operations (i.e.  the  URLs  in  one  \u001b[4m-:,\u001b[24m  \u001b[4m--next\u001b[24m\u001b[m\r\n              clause), will append them to the same file, separated by a blank line.\u001b[m\r\n\u001b[m\r\n              If \u001b[4m\u001b[7m-D\u001b[27m\u001b[24m\u001b[4m,\u001b[24m \u001b[4m--dump-header\u001b[24m is provided several times, the last set value will be used.\u001b[m\r\n\u001b[m\r\n              Example:\u001b[m\r\n               curl --dump-header store.txt https://example.com\u001b[m\r\n\u001b[m\r\n              See also \u001b[4m-o,\u001b[24m \u001b[4m--output\u001b[24m.\u001b[m\r\n\u001b[m\r\n       --egd-file <file>\u001b[m\r\n              (TLS)  Deprecated  option.  This option is ignored by"]
[58.436752, "o", " curl since 7.84.0. Prior to that it\u001b[m\r\n              only had an effect on curl if built to use old versions of OpenSSL.\u001b[m\r\n\u001b[m\r\n              Specify the path name to the Entropy Gathering Daemon socket. The socket is used to  seed\u001b[m\r\n              the random engine for SSL connections.\u001b[m\r\n\u001b[7m Manual page curl(1) line 996 (press h for help or q to quit)\u001b[27m\u001b[K"]
[59.620718, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[59.620898, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 995 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.12211, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              See also \u001b[4m--doh-insecure\u001b[24m. Added in 7.62.0.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 994 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.153888, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 993 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.1863, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[60.186417, "o", "\u001b[H\u001bM               curl --doh-url https://doh.example https://example.com\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 992 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.217695, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              Example:\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 991 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.249057, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 990 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.280116, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              If \u001b[4m--doh-url\u001b[24m is provided several times, the last set value will be used.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 989 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.311776, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 988 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.343652, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[60.343677, "o", "\u001b[H\u001bM              This option is unset if an empty string \"\" is used as the URL. (Added in 7.85.0)\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 987 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.375216, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 986 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.40689, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              can be controlled separately via \u001b[4m--doh-insecure\u001b[24m and \u001b[4m--doh-cert-status\u001b[24m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 985 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.439119, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              take place over SSL. However, the certificate verification settings are not inherited and\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 984 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.470203, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              Some SSL options that you set for your transfer will apply to DoH since the name  lookups\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 983 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.50126, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 982 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.53247, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              the default name resolver mechanism. The URL must be HTTPS.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 981 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.563379, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              Specifies which DNS-over-HTTPS (DoH) server to use to resolve hostnames, instead of using\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 980 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.594343, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
