[76.684365, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[3Phttp://localhost:5000/1"]
[76.812102, "o", "\r\u001b[C\u001b[Cman curl\u001b[K"]
[76.939896, "o", "\r\u001b[C\u001b[C\u001b[K"]
[77.606537, "o", "\u001b[H\u001b[2J\u001b[94mITINF25/lektion9\r\r\n\u001b(B\u001b[m$ "]
[77.965607, "o", "t"]
[78.101097, "o", "l"]
[78.183814, "o", "d"]
[78.349188, "o", "r"]
[78.469417, "o", " "]
[79.489286, "o", "c"]
[79.618136, "o", "u"]
[79.729737, "o", "r"]
[79.849714, "o", "l"]
[80.194666, "o", "\r\n"]
[80.194696, "o", "\u001b[?2004l\r"]
[80.220129, "o", "curl\r\n\r\n"]
[80.220401, "o", "\u001b[0m\u001b[0mTransfers data from or to a server.\r\nSupports most protocols, including HTTP, HTTPS, FTP, SCP, etc.\r\n"]
[80.220419, "o", "More information: https://curl.se/docs/manpage.html.\r\n\r\n"]
[80.220433, "o", " - \u001b[0m\u001b[32;23;22;24;25mMake an HTTP GET request and dump the contents in stdout:\r\n"]
[80.220456, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0mhttps://example.com\r\n"]
[80.220469, "o", "\u001b[0m\r\n"]
[80.220483, "o", " - \u001b[0m\u001b[32;23;22;24;25mMake an HTTP GET request, follow any 3xx redirects, and dump the reply headers and contents to stdout:\r\n"]
[80.220505, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0m[-L|--location]\u001b[33;23;22;24;25m \u001b[0m[-D|--dump-header]\u001b[33;23;22;24;25m - \u001b[0mhttps://example.com\r\n"]
[80.220516, "o", "\u001b[0m\r\n - \u001b[0m\u001b[32;23;22;24;25mDownload a file, saving the output under the filename indicated by the URL:\r\n"]
[80.220536, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0m[-O|--remote-name]\u001b[33;23;22;24;25m \u001b[0mhttps://example.com/filename.zip\r\n"]
[80.220541, "o", "\u001b[0m\r\n"]
[80.22056, "o", " - \u001b[0m\u001b[32;23;22;24;25mSend form-encoded data (POST request of type application/x-www-form-urlencoded). Use --data @file_name or --data @'-' to read from stdin:\r\n"]
[80.220577, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0m[-X|--request]\u001b[33;23;22;24;25m POST \u001b[0m[-d|--data]\u001b[33;23;22;24;25m \u001b[0m'name=bob'\u001b[33;23;22;24;25m \u001b[0mhttp://example.com/form\r\n"]
[80.220588, "o", "\u001b[0m\r\n"]
[80.220599, "o", " - \u001b[0m\u001b[32;23;22;24;25mSend a request with an extra header, using a custom HTTP method and over a proxy (such as BurpSuite), ignoring insecure self-signed certificates:\r\n"]
[80.220635, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0m[-k|--insecure]\u001b[33;23;22;24;25m \u001b[0m[-x|--proxy]\u001b[33;23;22;24;25m \u001b[0mhttp://127.0.0.1:8080\u001b[33;23;22;24;25m \u001b[0m[-H|--header]\u001b[33;23;22;24;25m \u001b[0m'Authorization: Bearer token'\u001b[33;23;22;24;25m \u001b[0m[-X|--request]\u001b[33;23;22;24;25m \u001b[0mGET|PUT|POST|DELETE|PATCH|...\u001b[33;23;22;24;25m \u001b[0mhttps://example.com\r\n"]
[80.220649, "o", "\u001b[0m\r\n"]
[80.220659, "o", " - \u001b[0m\u001b[32;23;22;24;25mSend data in JSON format, specifying the appropriate Content-Type header:\r\n"]
[80.220679, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0m[-d|--data]\u001b[33;23;22;24;25m {{'{\"name\":\"bob\"}'}} \u001b[0m[-H|--header]\u001b[33;23;22;24;25m \u001b[0m'Content-Type: application/json'\u001b[33;23;22;24;25m \u001b[0mhttp://example.com/users/1234\r\n"]
[80.220689, "o", "\u001b[0m\r\n"]
[80.220701, "o", " - \u001b[0m\u001b[32;23;22;24;25mPass client certificate and key for a resource, skipping certificate validation:\r\n"]
[80.220747, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0m[-E|--cert]\u001b[33;23;22;24;25m \u001b[0mclient.pem\u001b[33;23;22;24;25m --key \u001b[0mkey.pem\u001b[33;23;22;24;25m \u001b[0m[-k|--insecure]\u001b[33;23;22;24;25m \u001b[0mhttps://example.com\r\n\u001b[0m\r\n"]
[80.220765, "o", " - \u001b[0m\u001b[32;23;22;24;25mResolve a hostname to a custom IP address, with verbose output (similar to editing the /etc/hosts file for custom DNS resolution):\r\n"]
[80.220782, "o", "   \u001b[33;23;22;24;25mcurl \u001b[0m[-v|--verbose]\u001b[33;23;22;24;25m --resolve \u001b[0mexample.com\u001b[33;23;22;24;25m:\u001b[0m80\u001b[33;23;22;24;25m:\u001b[0m127.0.0.1\u001b[33;23;22;24;25m \u001b[0mhttp://example.com\r\n"]
[80.220805, "o", "\u001b[0m\u001b[0m"]
