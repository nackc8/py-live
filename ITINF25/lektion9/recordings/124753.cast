[68.859051, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       --digest\u001b[m\r\n\u001b[7m Manual page curl(1) line 802 (press h for help or q to quit)\u001b[27m\u001b[K"]
[69.334017, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               curl -d @filename https://example.com\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 801 (press h for help or q to quit)\u001b[27m\u001b[K"]
[74.426958, "o", "\r\u001b[K\u001b[?1l\u001b>\u001b[?1049l\u001b[23;0;0t"]
[74.432244, "o", "\u001b[?2004h\u001b[94mITINF25/lektion9\r\r\n\u001b(B\u001b[m$ "]
