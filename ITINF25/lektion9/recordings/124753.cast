[67.798983, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              the @ character to have a special interpretation use \u001b[4m--data-raw\u001b[24m instead.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 794 (press h for help or q to quit)\u001b[27m\u001b[K"]
