[67.642217, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               curl -d \"name=curl\" https://example.com\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page curl(1) line 799 (press h for help or q to quit)\u001b[27m\u001b[K"]
