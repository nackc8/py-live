[3160.088112, "o", "\u001b[1;1H              Specify     a    proxy    in    the    form\u001b[m\r\n\u001b[2;1H              \u001b[1m[user:passwd@]proxy.server:port\u001b[0m.\u001b[m\r\n\u001b[3;1H\u001b[m\r\n\u001b[4;1H       \u001b[1m--timeout\u001b[0m \u001b[4m<sec>\u001b[24m\u001b[m\r\n\u001b[5;1H              Set the socket  timeout  (default  15  sec‐\u001b[m\r\n\u001b[6;1H              onds).\u001b[m\r\n\u001b[7;1H\u001b[m\r\n\u001b[8;1H       \u001b[1m--exists-action\u001b[0m \u001b[4m<action>\u001b[24m\u001b[m\r\n\u001b[9;1H              Default  action when a path already exists:\u001b[m\r\n\u001b[10;1H              (s)witch, (i)gnore, (w)ipe, (b)ackup.\u001b[m\r\n\u001b[11;1H\u001b[m\r\n\u001b[12;1H       \u001b[1m--cert\u001b[0m \u001b[4m<path>\u001b[24m\u001b[m\r\n\u001b[13;1H              Path to alternate CA bundle.\u001b[m\r\n\u001b[14;1H\u001b[1;1H              Specify     a    proxy    in    the    form\u001b[m\r\n\u001b[2;1H              \u001b[1m[user:passwd@]proxy.server:port\u001b[0m.\u001b[m\r\n\u001b[3;1H\u001b[m\r\n\u001b[4;1H       \u001b[1m--timeout\u001b[0m \u001b[4m<sec>\u001b[24m\u001b[m\r\n\u001b[5;1H              Set the socket  timeout  (default  15  sec‐\u001b[m\r\n\u001b[6;1H              onds).\u001b[m\r\n\u001b[7;1H\u001b[m\r\n\u001b[8;1H       \u001b[1m--exists-action\u001b[0m \u001b[4m<action>\u001b[24m\u001b[m\r\n\u001b[9;1H              Default  action when "]
[3160.088125, "o", "a path already exist"]
[3160.088393, "o", "s:\u001b[m\r\n\u001b[10;1H              (s)witch, (i)gnore, (w)ipe, (b)ackup.\u001b[m\r\n\u001b[11;1H\u001b[m\r\n\u001b[12;1H       \u001b[1m--cert\u001b[0m \u001b[4m<path>\u001b[24m\u001b[m\r\n\u001b[13;1H              Path to alternate CA bundle.\u001b[m\r\n\u001b[14;1H"]
[3160.08846, "o", "...skipping...\r\n       \u001b[1m\u001b[7m-U\u001b[27m\u001b[0m, \u001b[1m--upgrade\u001b[0m\u001b[m\r\n              Upgrade all packages to the  newest  avail‐\u001b[m\r\n              able  version.   This  process is recursive\u001b[m\r\n              regardless of whether a dependency  is  al‐\u001b[m\r\n              ready satisfied.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--force-reinstall\u001b[0m\u001b[m\r\n              When upgrading, reinstall all packages even\u001b[m\r\n              if they are already up-to-date.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-I\u001b[0m, \u001b[1m--ignore-installed\u001b[0m\u001b[m\r\n              Ignore the installed packages (reinstalling\u001b[m\r\n              instead).\u001b[m\r\n\u001b[7m pip3(1) line 136/268 52% (press h for help or q to quit)\u001b[27m\u001b[K"]
