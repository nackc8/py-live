[3149.974429, "o", "PIP(1)           General Commands Manual           PIP(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       pip  -  A  tool for installing and managing Python\u001b[m\r\n       packages\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       pip <command> [options]\u001b[m\r\n\u001b[m\r\n       pip3 <command> [options]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mpip\u001b[0m is a Python package installer, recommended for\u001b[m\r\n\u001b[7manual page pip3(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3153.052343, "o", "\r\u001b[K       installing Python packages which are not available\u001b[m\r\n       in the Debian archive.  It can work  with  version\u001b[m\r\n       control  repositories  (currently only Git, Mercu‐\u001b[m\r\n       rial, and Bazaar repositories), logs output exten‐\u001b[m\r\n       sively, and prevents partial installs by download‐\u001b[m\r\n       ing all requirements before starting installation.\u001b[m\r\n\u001b[m\r\n       On Debian, \u001b[1mpip\u001b[0m is the  command  to  use  when  in‐\u001b[m\r\n       stalling  packages for Python 2, while \u001b[1mpip3\u001b[0m is the\u001b[m\r\n       command to use when installing packages for Python\u001b[m\r\n       3.\u001b[m\r\n\u001b[m\r\n\u001b[1mCOMMANDS\u001b[0m\u001b[m\r\n\u001b[7mnual page pip3(1) line 14 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3153.637055, "o", "\r\u001b[K       The command comes before any options.  The follow‐\u001b[m\r\n       ing commands are recognized:\u001b[m\r\n\u001b[m\r\n       \u001b[1mhelp\u001b[0m   Show help for commands.\u001b[m\r\n\u001b[m\r\n       \u001b[1minstall\u001b[0m\u001b[m\r\n              Install packages.\u001b[m\r\n\u001b[m\r\n       \u001b[1muninstall\u001b[0m\u001b[m\r\n              Uninstall packages.\u001b[m\r\n\u001b[m\r\n       \u001b[1mfreeze\u001b[0m Output installed packages  in  requirements\u001b[m\r\n              format.\u001b[m\r\n\u001b[7mnual page pip3(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3155.767663, "o", "\r\u001b[K\u001b[m\r\n       \u001b[1mlist\u001b[0m   List installed packages.\u001b[m\r\n\u001b[m\r\n       \u001b[1mshow\u001b[0m   Show information about installed packages.\u001b[m\r\n\u001b[m\r\n       \u001b[1msearch\u001b[0m Search PyPI for packages.\u001b[m\r\n\u001b[m\r\n       \u001b[1mwheel\u001b[0m  Build wheels from your requirements.\u001b[m\r\n\u001b[m\r\n\u001b[1mGENERAL\u001b[0m \u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       This list is by no means complete, and it only de‐\u001b[m\r\n       scribes options available to  all  commands.   Use\u001b[m\r\n       \u001b[1mpip\u001b[0m  \u001b[1m<command>\u001b[0m  \u001b[1m--help\u001b[0m for more details on command\u001b[m\r\n\u001b[7mnual page pip3(1) line 40 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3156.096473, "o", "\r\u001b[K"]
[3156.096562, "o", "       specific options.  A few command options are  pro‐\u001b[m\r\n       vided below.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m\u001b[m\r\n              Show more detailed command help.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-v\u001b[0m, \u001b[1m--verbose\u001b[0m\u001b[m\r\n              Give  more  output. Option is additive, and\u001b[m\r\n              can be used up to 3 times.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-V\u001b[0m, \u001b[1m--version\u001b[0m\u001b[m\r\n              Show version and exit.\u001b[m\r\n\u001b[m\r\n\u001b[7mnual page pip3(1) line 53 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3156.472733, "o", "\r\u001b[K       \u001b[1m-q\u001b[0m, \u001b[1m--quiet\u001b[0m\u001b[m\r\n              Give less output.\u001b[m\r\n"]
[3156.472756, "o", "\u001b[m\r\n       \u001b[1m--log-file\u001b[0m \u001b[4m<path>\u001b[24m\u001b[m\r\n              Path to a verbose non-appending  log,  that\u001b[m\r\n              only  logs failures.  This log is active by\u001b[m\r\n              default at \u001b[4m~/.pip/pip.log\u001b[24m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--log\u001b[0m \u001b[4m<path>\u001b[24m\u001b[m\r\n              Path to a verbose appending log.  This  log\u001b[m\r\n              is inactive by default.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--proxy\u001b[0m \u001b[4m<proxy>\u001b[24m\u001b[m\r\n\u001b[7mnual page pip3(1) line 66 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3157.350102, "o", "\r\u001b[K              Specify     a    proxy    in    the    form\u001b[m\r\n              \u001b[1m[user:passwd@]proxy.server:port\u001b[0m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--timeout\u001b[0m \u001b[4m<sec>\u001b[24m\u001b[m\r\n              Set the socket  timeout  (default  15  sec‐\u001b[m\r\n              onds).\u001b[m\r\n\u001b[m\r\n       \u001b[1m--exists-action\u001b[0m \u001b[4m<action>\u001b[24m\u001b[m\r\n              Default  action when a path already exists:\u001b[m\r\n              (s)witch, (i)gnore, (w)ipe, (b)ackup.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--cert\u001b[0m \u001b[4m<path>\u001b[24m\u001b[m\r\n              Path to alternate CA bundle.\u001b[m\r\n\u001b[7mnual page pip3(1) line 79 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3158.212564, "o", "\r\u001b[K/"]
